# Google Gemini (recommended — paste your Gemini API key here)
VITE_GEMINI_API_KEY=
# Stabil & jarang 503. Hindari model preview yang overload (mis. gemini-3.5-flash).
VITE_GEMINI_MODEL=gemini-2.0-flash

# Alternative: OpenAI-compatible API (OpenAI, Groq, etc.)
# VITE_AI_API_KEY=
# VITE_AI_API_BASE=https://api.openai.com/v1
# VITE_AI_MODEL=gpt-4o-mini

# Copy this file to .env.local and add your key, then restart: npm run dev
